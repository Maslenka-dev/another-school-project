<UserControl x:Class="ProductivityTimer.Views.PomodoroView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360" />
                <ColumnDefinition Width="20" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock Text="Режим Pomodoro"
                               Style="{StaticResource SectionTitleTextStyle}" />

                    <ComboBox Margin="0,18,0,0"
                              ItemsSource="{Binding AvailableModes}"
                              SelectedItem="{Binding SelectedMode}"
                              DisplayMemberPath="DisplayName"
                              IsEnabled="{Binding IsModeSelectionEnabled}" />

                    <Border Margin="0,10,0,0"
                            Style="{StaticResource AccentCardBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="Состояние"
                                       Style="{StaticResource FieldLabelTextStyle}" />
                            <TextBlock Margin="0,8,0,0"
                                       FontSize="22"
                                       FontWeight="SemiBold"
                                       Text="{Binding RunStateText}" />
                        </StackPanel>
                    </Border>

                    <Grid Margin="0,26,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                Content="Старт"
                                Command="{Binding StartCommand}" />
                        <Button Grid.Column="2"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Content="Пауза"
                                Command="{Binding PauseCommand}" />
                        <Button Grid.Column="4"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Content="Сброс"
                                Margin="0"
                                Command="{Binding ResetCommand}" />
                    </Grid>
                </StackPanel>
            </Border>

            <StackPanel Grid.Column="2">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Style="{StaticResource MetricCardBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="Режим"
                                       Style="{StaticResource FieldLabelTextStyle}" />
                            <TextBlock Margin="0,10,0,0"
                                       FontSize="24"
                                       FontWeight="SemiBold"
                                       Text="{Binding SelectedMode.DisplayName, TargetNullValue=—}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2"
                            Style="{StaticResource MetricCardBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="Фаза"
                                       Style="{StaticResource FieldLabelTextStyle}" />
                            <TextBlock Margin="0,10,0,0"
                                       FontSize="24"
                                       FontWeight="SemiBold"
                                       Text="{Binding CurrentPhase}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="4"
                            Style="{StaticResource MetricCardBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="Цикл"
                                       Style="{StaticResource FieldLabelTextStyle}" />
                            <TextBlock Margin="0,10,0,0"
                                       FontSize="24"
                                       FontWeight="SemiBold"
                                       Text="{Binding CycleNumber}" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Border Margin="0,16,0,0"
                        Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="Оставшееся время"
                                   Style="{StaticResource SectionTitleTextStyle}" />
                        <TextBlock Margin="0,18,0,0"
                                   Style="{StaticResource HeroValueTextStyle}"
                                   FontSize="64"
                                   Text="{Binding RemainingTimeText}" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>


