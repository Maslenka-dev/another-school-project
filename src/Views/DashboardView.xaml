<UserControl x:Class="ProductivityTimer.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style x:Key="TaskRowBorderStyle" TargetType="Border" BasedOn="{StaticResource MetricCardBorderStyle}">
            <Setter Property="Padding" Value="14,12" />
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>

        <Style x:Key="TaskActionButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Width" Value="40" />
            <Setter Property="MinWidth" Value="40" />
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,8,0" />
        </Style>

        <Style x:Key="TaskDeleteButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource DangerSoftButtonStyle}">
            <Setter Property="Width" Value="40" />
            <Setter Property="MinWidth" Value="40" />
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
        </Style>

        <Style x:Key="TaskTitleDisplayStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource MutedForegroundBrush}" />
                    <Setter Property="TextDecorations" Value="Strikethrough" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TaskTitleEditorStyle" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="Margin" Value="0" />
            <Setter Property="Padding" Value="10,6" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsEditing}" Value="False">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TaskPlaceholderTextStyle" TargetType="TextBlock" BasedOn="{StaticResource HelperTextStyle}">
            <Setter Property="Margin" Value="12,0,0,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="IsHitTestVisible" Value="False" />
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding IsEditing}" Value="True" />
                        <Condition Binding="{Binding Title}" Value="" />
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Visibility" Value="Visible" />
                </MultiDataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="EditTaskButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="MinWidth" Value="68" />
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Content" Value="Изм." />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                    <Setter Property="Content" Value="Сохр." />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="EmptyTasksBorderStyle" TargetType="Border" BasedOn="{StaticResource CardBorderStyle}">
            <Setter Property="Background" Value="#FFFDFEFF" />
            <Setter Property="Padding" Value="26" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Top" />
            <Setter Property="Width" Value="500" />
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Tasks.Count}" Value="0">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PomodoroPhaseBadgeStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="Padding" Value="12,6" />
        </Style>

        <Style x:Key="PomodoroMetaChipStyle" TargetType="Border">
            <Setter Property="Background" Value="#CCFFFFFF" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="12,8" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Margin="0,0,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.35*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock Text="Москва (UTC+3)"
                               Style="{StaticResource SectionTitleTextStyle}" />
                    <TextBlock Margin="0,16,0,0"
                               Style="{StaticResource HeroValueTextStyle}"
                               Text="{Binding CurrentTimeText}" />
                    <TextBlock Margin="0,8,0,0"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Text="{Binding CurrentDateText}" />
                </StackPanel>
            </Border>

            <Border Grid.Column="2"
                    Style="{StaticResource AccentCardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Pomodoro сейчас"
                                   Style="{StaticResource SectionTitleTextStyle}" />

                        <Border Grid.Column="1"
                                Style="{StaticResource PomodoroPhaseBadgeStyle}">
                            <TextBlock FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource AccentBrush}"
                                       Text="{Binding PomodoroPhaseText}" />
                        </Border>
                    </Grid>

                    <TextBlock Grid.Row="1"
                               Margin="0,22,0,0"
                               FontSize="44"
                               FontWeight="SemiBold"
                               Text="{Binding PomodoroRemainingTimeText}" />

                    <StackPanel Grid.Row="2"
                                Margin="0,16,0,0">
                        <Border HorizontalAlignment="Left"
                                Style="{StaticResource PomodoroMetaChipStyle}">
                            <TextBlock FontSize="14"
                                       FontWeight="SemiBold"
                                       Text="{Binding PomodoroCycleText}" />
                        </Border>

                        <TextBlock Margin="0,14,0,0"
                                   Style="{StaticResource HelperTextStyle}"
                                   Text="Управляйте с отдельной вкладки" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="1"
                Style="{StaticResource CardBorderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Список задач на сегодня"
                               Style="{StaticResource SectionTitleTextStyle}" />

                    <Button Grid.Column="1"
                            Width="46"
                            MinWidth="46"
                            Height="46"
                            Margin="16,0,0,0"
                            Padding="0"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center"
                            Command="{Binding AddTaskCommand}">
                        <TextBlock Text="+"
                                   FontSize="26"
                                   FontWeight="Medium"
                                   TextAlignment="Center"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Button>
                </Grid>

                <Grid Grid.Row="1"
                      Margin="0,16,0,0"
                      MinHeight="300">
                    <Border Style="{StaticResource EmptyTasksBorderStyle}">
                        <StackPanel HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                            <TextBlock Margin="0,16,0,0"
                                       HorizontalAlignment="Center"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       Text="Сегодня пока нет задач" />
                            <TextBlock Margin="0,8,0,0"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center"
                                       Style="{StaticResource HelperTextStyle}"
                                       Text="Добавьте первую задачу кнопкой &quot;+&quot;, чтобы начать работу." MaxWidth="340" />
                        </StackPanel>
                    </Border>

                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ScrollViewer.Style>
                            <Style TargetType="ScrollViewer">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Tasks.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ScrollViewer.Style>

                        <ItemsControl ItemsSource="{Binding Tasks}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource TaskRowBorderStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <CheckBox Margin="0,0,14,0"
                                                      VerticalAlignment="Center"
                                                      IsChecked="{Binding IsCompleted, Mode=TwoWay}" />

                                            <Grid Grid.Column="1"
                                                  Margin="0,0,16,0">
                                                <TextBlock Style="{StaticResource TaskTitleDisplayStyle}"
                                                           Text="{Binding Title}" />
                                                <TextBox Style="{StaticResource TaskTitleEditorStyle}"
                                                         Text="{Binding Title, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                <TextBlock Style="{StaticResource TaskPlaceholderTextStyle}"
                                                           Text="Новая задача" />
                                            </Grid>

                                            <StackPanel Grid.Column="2"
                                                        Orientation="Horizontal"
                                                        VerticalAlignment="Center">
                                                <Button Style="{StaticResource TaskActionButtonStyle}"
                                                        Command="{Binding DataContext.MoveUpTaskCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Content="↑" />

                                                <Button Style="{StaticResource TaskActionButtonStyle}"
                                                        Command="{Binding DataContext.MoveDownTaskCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Content="↓" />

                                                <Button Style="{StaticResource EditTaskButtonStyle}"
                                                        Command="{Binding DataContext.EditTaskCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}" />

                                                <Button Style="{StaticResource TaskDeleteButtonStyle}"
                                                        Command="{Binding DataContext.DeleteTaskCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}">
                                                    <TextBlock FontFamily="Segoe MDL2 Assets"
                                                               FontSize="16"
                                                               Text="&#xE74D;" />
                                                </Button>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>














