<Application x:Class="ProductivityTimer.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:viewModels="clr-namespace:ProductivityTimer.ViewModels"
             xmlns:views="clr-namespace:ProductivityTimer.Views"
             ShutdownMode="OnMainWindowClose">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Theme.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <DataTemplate DataType="{x:Type viewModels:DashboardViewModel}">
                <views:DashboardView />
            </DataTemplate>

            <DataTemplate DataType="{x:Type viewModels:PomodoroViewModel}">
                <views:PomodoroView />
            </DataTemplate>

            <DataTemplate DataType="{x:Type viewModels:TimerViewModel}">
                <views:TimerView />
            </DataTemplate>

            <DataTemplate DataType="{x:Type viewModels:StopwatchViewModel}">
                <views:StopwatchView />
            </DataTemplate>

            <DataTemplate DataType="{x:Type viewModels:StatisticsViewModel}">
                <views:StatisticsView />
            </DataTemplate>
        </ResourceDictionary>
    </Application.Resources>
</Application>
